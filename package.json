{
  "name": "ehentai",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "pnpm typecheck && node --import tsx build/generate-manifest.ts && cross-env NODE_OPTIONS=\"--import tsx\" rspack build && node --import tsx build/generate-brotli.ts",
    "test": "vitest run --passWithNoTests",
    "test:smoke": "vitest run test/integration.smoke.spec.ts",
    "verify": "pnpm typecheck && pnpm test && pnpm build",
    "dev": "pnpm dev:serve",
    "dev:serve": "tsx dev-server.ts",
    "dev:server": "tsx dev-server.ts"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "cheerio": "^1.2.0"
  },
  "devDependencies": {
    "@rspack/cli": "^2.0.0",
    "@rspack/core": "^2.0.0",
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}