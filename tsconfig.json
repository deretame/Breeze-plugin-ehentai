{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "lib": [
      "ES2020",
      "DOM"
    ],
    "noEmit": true
  },
  "include": [
    "rspack.config.ts",
    "rspack.shared.ts",
    "src/**/*.ts",
    "types/**/*.ts",
    "types/**/*.d.ts",
    "test/**/*.ts"
  ]
}